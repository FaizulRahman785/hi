rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read and write their own profile document
    // Profile docs are keyed by the user's Firebase UID
    match /profiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow users to read/write their own profile if the doc is keyed by email (legacy fallback)
    match /profiles/{email} {
      allow read, write: if request.auth != null && request.auth.token.email == email;
    }
  }
}
