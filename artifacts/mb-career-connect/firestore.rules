rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidProfileWrite(userId) {
      return request.resource.data.uid == userId
        && (!('email' in request.resource.data) || request.resource.data.email == request.auth.token.email)
        && (!('onboardingCompleted' in request.resource.data) || request.resource.data.onboardingCompleted is bool)
        && (!('profileCompletion' in request.resource.data) || request.resource.data.profileCompletion is number);
    }

    match /profiles/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create, update: if isOwner(userId) && isValidProfileWrite(userId);
      allow delete: if isOwner(userId);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
