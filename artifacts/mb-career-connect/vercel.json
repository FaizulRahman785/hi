{
  "version": 2,
  "buildCommand": "cd ../.. && pnpm --filter @workspace/mb-career-connect run build",
  "outputDirectory": "dist/public",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
